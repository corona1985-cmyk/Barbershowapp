rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAnonymousSupport() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'anonymous';
    }

    /** serverTimestamp() en reglas debe coincidir con request.time al evaluar el create. */
    function isValidFeedback(data, reqTime) {
      return data.keys().hasOnly([
        'userId',
        'username',
        'reason',
        'customReason',
        'improvementFeedback',
        'createdAt',
        'platform',
        'appVersion'
      ])
      && data.userId is string
      && data.username is string
      && data.reason in [
        'no_longer_need_app',
        'found_another_barbershop',
        'technical_issues',
        'hard_to_use',
        'too_many_notifications',
        'account_issues',
        'privacy_security',
        'other'
      ]
      && data.platform in ['web', 'ios', 'android', 'unknown']
      && data.appVersion is string
      && data.appVersion.size() <= 40
      && data.userId.size() <= 64
      && data.username.size() <= 64
      && data.createdAt == reqTime
      && (!('customReason' in data) || data.customReason == null || (data.customReason is string && data.customReason.size() <= 2000))
      && (!('improvementFeedback' in data) || data.improvementFeedback == null || (data.improvementFeedback is string && data.improvementFeedback.size() <= 2000));
    }

    match /account_deactivation_feedback/{docId} {
      allow create: if isAnonymousSupport() && isValidFeedback(request.resource.data, request.time);
      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
